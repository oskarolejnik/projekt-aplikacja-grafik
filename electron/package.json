{
  "name": "lokalo-desktop",
  "productName": "Lokalo",
  "version": "1.0.0",
  "description": "Lokalo — aplikacja desktopowa do zarządzania lokalem gastronomicznym",
  "author": "Oskar Olejnik",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env VITE_DEV=1 electron .",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "app.lokalo.desktop",
    "productName": "Lokalo",
    "copyright": "© Oskar Olejnik",
    "directories": {
      "output": "dist-installer",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "Lokalo-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lokalo",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerLanguages": ["pl_PL"],
      "language": "1045"
    }
  }
}
