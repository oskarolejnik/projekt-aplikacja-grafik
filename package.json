{
  "name": "lokalo",
  "version": "1.0.0",
  "description": "Lokalo — zarządzanie lokalem gastronomicznym",
  "main": "electron/main.js",
  "scripts": {
    "start": "cd frontend && npm run build && cd .. && electron .",
    "start:dev": "VITE_DEV=1 electron .",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "build": "cd frontend && npm run build && cd .. && electron-builder"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "app.lokalo.desktop",
    "productName": "Lokalo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    }
  }
}
