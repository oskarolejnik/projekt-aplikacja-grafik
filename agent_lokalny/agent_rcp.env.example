# ── Konfiguracja agenta RCP (PowerShell) ─────────────────────────────────────
# Skopiuj do `agent_rcp.env` i uzupełnij. Trzymaj TYLKO na serwerze lokalnym.
# Nigdy w repo, nigdy na VPS. (agent_rcp.env jest w .gitignore.)

# 1) Połączenie do SQL Server (System.Data.SqlClient) — KONTO TYLKO DO ODCZYTU (db_datareader).
#    Instancja domyślna:   Server=SERWER        lub  Server=SERWER,1433
#    Instancja nazwana:    Server=SERWER\INSTANCJA      (SqlClient sam znajdzie port przez SQL Browser)
#    Logowanie SQL:
RCP_CONNECTION_STRING=Server=srvrajcula;Database=Gastro;User Id=czytelnik_rcp;Password=HASLO;TrustServerCertificate=True
#    ...albo logowanie Windows (konto, na którym chodzi zadanie, musi mieć odczyt do Gastro):
# RCP_CONNECTION_STRING=Server=srvrajcula;Database=Gastro;Integrated Security=SSPI;TrustServerCertificate=True

# 2) Zapytanie — MUSI zwrócić aliasy: rcp_id, imie_nazwisko, data, wejscie, wyjscie.
#    Parametry: @start, @end (zakres dat). Gotowe, sprawdzone dla NGastroCzasPracy:
RCP_SQL=SELECT CONVERT(NVARCHAR(36), z.ID) AS rcp_id, LTRIM(RTRIM(o.Imie + ' ' + o.Nazwisko)) AS imie_nazwisko, CAST(z.DataPoczatek AS DATE) AS data, z.DataPoczatek AS wejscie, CASE WHEN z.DataKoniec < '1900-01-02' THEN NULL ELSE z.DataKoniec END AS wyjscie FROM dbo.NGastroCzasPracy z WITH (NOLOCK) JOIN dbo.NGastroUzytkownik u WITH (NOLOCK) ON u.ID = z.UzytkownikID JOIN dbo.NSysOperator o WITH (NOLOCK) ON o.ID = u.OperatorID WHERE CAST(z.DataPoczatek AS DATE) BETWEEN @start AND @end

# 3) VPS — adres endpointu (HTTPS!) i wspólny token (taki sam jak RCP_INGEST_TOKEN na VPS).
VPS_INGEST_URL=https://twoja-domena.pl/api/rcp/ingest
RCP_INGEST_TOKEN=wygeneruj-dlugi-losowy-sekret

# 4) Parametry pętli.
POLL_SECONDS=30      # co ile sekund odpytywać RCP (30-60 = praktycznie na żywo)
OKNO_DNI=2           # ile dni wstecz skanować w każdym cyklu
QUERY_TIMEOUT=30

# 5) STOŁY (live z Gastro) — OPCJONALNE. Jeśli puste, agent ich nie wysyła (RCP działa dalej).
#    Zwraca: rewir_nr, otwarte. To OSOBNE zapytanie — nie dotyka RCP/godzin.
VPS_STOLY_URL=https://twoja-domena.pl/api/gastro/stoly
STOLY_SQL=SELECT u.Numer AS rewir_nr, COUNT(r.ID) AS otwarte FROM dbo.NGastroUzytkownik u WITH (NOLOCK) LEFT JOIN dbo.NGastroDTRachunek r WITH (NOLOCK) ON r.UzytkownikOtwierajacyID = u.ID AND r.DataZamkniecia < '1900-01-02' AND r.DataOtwarcia >= DATEADD(HOUR, -18, GETDATE()) WHERE u.Numer IN (42,52,53,54,55,56,57,108,46) GROUP BY u.Numer
