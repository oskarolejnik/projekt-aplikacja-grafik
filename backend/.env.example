# Skopiuj do backend/.env i dostosuj wartości.

# --- Baza danych ---
# PostgreSQL (cel produkcyjny). Dla szybkiego dev można użyć SQLite:
#   DATABASE_URL=sqlite:///./scheduler.db
DATABASE_URL=postgresql+psycopg2://grafik:grafik@localhost:5432/grafik

# --- Bezpieczeństwo ---
# Sekret do podpisywania tokenów JWT. USTAW własny, długi, losowy ciąg!
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=zmien-mnie-na-dlugi-losowy-sekret
# Czas życia tokenu dostępu (w minutach)
TOKEN_TTL_MINUTES=720

# --- Konto administratora ---
# Tworzenie admina z .env jest WYŁĄCZONE. Admina zakłada się skryptem:
#   python create_admin.py
# (Poniższe zmienne są ignorowane — możesz je pominąć.)

# --- CORS ---
# Lista dozwolonych originów oddzielona przecinkami, lub * dla wszystkich.
# W produkcji ogranicz do adresu frontendu, np. https://grafik.twojadomena.pl
CORS_ORIGINS=*

# --- Powiadomienia Web Push (PWA) ---
# Wygeneruj klucze raz:  python generate_vapid.py  (i wklej wynik tutaj)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=vapid_private.pem
VAPID_SUBJECT=mailto:admin@twojadomena.pl
