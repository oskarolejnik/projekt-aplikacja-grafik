# Konfiguracja produkcyjnego stacku Docker (docker-compose.prod.yml).
# Skopiuj do .env (obok pliku compose) i uzupełnij. Plik .env jest w .gitignore.

# Domena instancji (DNS musi wskazywać na ten serwer) — Caddy pobierze certyfikat TLS.
# Do testów lokalnych zostaw localhost (wtedy HTTP, bez HTTPS).
DOMENA=twojadomena.pl

# Sekret JWT — długi, losowy. Wygeneruj:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# WYMAGANY: klucz szyfrowania PII gości at-rest (telefon/e-mail). Bez niego dane zapisują się
# jawnym tekstem (RODO art. 32) — aplikacja odmówi startu w produkcji. Wygeneruj jak SECRET_KEY.
# STAŁY: NIE zmieniaj po pierwszym zapisie danych (utracisz możliwość odszyfrowania).
ENCRYPTION_KEY=

# Lista zaufanych proxy dla nagłówków X-Forwarded-For (rate-limity liczą realne IP klienta).
# W stacku compose aplikacja jest osiągalna WYŁĄCZNIE przez Caddy w prywatnej sieci → '*' jest
# tu bezpieczne. Jeśli wystawisz port aplikacji publicznie, ustaw CIDR/IP swojego proxy.
FORWARDED_ALLOW_IPS=*

# Baza PostgreSQL (kontener db). Ustaw mocne hasło.
POSTGRES_USER=grafik
POSTGRES_PASSWORD=
POSTGRES_DB=grafik

# Token ingestu agenta POS/RCP (ten sam po stronie agenta) — pusty = ingest wyłączony.
RCP_INGEST_TOKEN=

# Czas życia tokenu (min). Puste = 720.
TOKEN_TTL_MINUTES=720

# CORS: puste = tylko same-origin (zalecane, bo front i API są pod tą samą domeną).
CORS_ORIGINS=

# Rezerwacje są kanonicznie przechowywane w bazie Lokalo. Nie konfiguruj już trybów
# legacy/shadow ani Google Calendar jako źródła prawdy.

# Web Push (PWA) — opcjonalne. Wygeneruj klucze: python backend/generate_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@twojadomena.pl

# Komunikacja operacyjna rezerwacji (opcjonalna). Brak kompletu wyłącza dany kanał,
# ale nie cofa zapisanej rezerwacji; operator widzi błąd w historii dostarczenia.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMS_API_URL=
SMS_API_TOKEN=
SMS_SENDER=
# Włącz wyłącznie po potwierdzeniu kontraktu idempotencji przez providera SMS.
SMS_SUPPORTS_IDEMPOTENCY=false
SMS_IDEMPOTENCY_HEADER=Idempotency-Key
RESERVATION_DELIVERY_INTERVAL_SECONDS=5

# Płatności rezerwacji są opcjonalne. Pozostaw puste do czasu założenia działalności
# i konta Stripe; wtedy polityki wymagające zadatku muszą pozostać wyłączone.
PAYMENTS_PROVIDER=
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_APP_URL=
STRIPE_API_VERSION=2026-06-24.dahlia
STRIPE_EXPECTED_LIVEMODE=false
RESERVATION_PAYMENT_INTERVAL_SECONDS=2
