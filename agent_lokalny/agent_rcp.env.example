# ── Konfiguracja agenta RCP (PowerShell) ─────────────────────────────────────
# Skopiuj do `agent_rcp.env` i uzupełnij. Trzymaj TYLKO na serwerze lokalnym.
# Nigdy w repo, nigdy na VPS. (agent_rcp.env jest w .gitignore.)

# 1) Połączenie do SQL Server (System.Data.SqlClient) — KONTO TYLKO DO ODCZYTU (db_datareader).
#    Instancja domyślna:   Server=SERWER        lub  Server=SERWER,1433
#    Instancja nazwana:    Server=SERWER\INSTANCJA      (SqlClient sam znajdzie port przez SQL Browser)
#    Logowanie SQL:
RCP_CONNECTION_STRING=Server=SERWER\INSTANCJA;Database=Gastro;User Id=czytelnik_rcp;Password=HASLO;TrustServerCertificate=True
#    ...albo logowanie Windows (konto, na którym chodzi zadanie, musi mieć odczyt do Gastro):
# RCP_CONNECTION_STRING=Server=SERWER\INSTANCJA;Database=Gastro;Integrated Security=SSPI;TrustServerCertificate=True

# 2) Zapytanie — MUSI zwrócić aliasy: rcp_id, imie_nazwisko, data, wejscie, wyjscie.
#    Parametry: @start, @end (zakres dat). Gotowe, sprawdzone dla NGastroCzasPracy:
RCP_SQL=SELECT CONVERT(NVARCHAR(36), z.ID) AS rcp_id, LTRIM(RTRIM(o.Imie + ' ' + o.Nazwisko)) AS imie_nazwisko, CAST(z.DataPoczatek AS DATE) AS data, z.DataPoczatek AS wejscie, CASE WHEN z.DataKoniec < '1900-01-02' THEN NULL ELSE z.DataKoniec END AS wyjscie FROM dbo.NGastroCzasPracy z WITH (NOLOCK) JOIN dbo.NGastroUzytkownik u WITH (NOLOCK) ON u.ID = z.UzytkownikID JOIN dbo.NSysOperator o WITH (NOLOCK) ON o.ID = u.OperatorID WHERE CAST(z.DataPoczatek AS DATE) BETWEEN @start AND @end

# 3) VPS — adres endpointu (HTTPS!) i wspólny token (taki sam jak RCP_INGEST_TOKEN na VPS).
VPS_INGEST_URL=https://twoja-domena.pl/api/rcp/ingest
RCP_INGEST_TOKEN=wygeneruj-dlugi-losowy-sekret

# 4) Parametry pętli.
POLL_SECONDS=30      # co ile sekund odpytywać RCP (30-60 = praktycznie na żywo)
OKNO_DNI=2           # ile dni wstecz skanować w każdym cyklu
QUERY_TIMEOUT=30

# 5) STOŁY (live z Gastro) — OPCJONALNE. Jeśli puste, agent ich nie wysyła (RCP działa dalej).
#    Zwraca: rewir_nr, otwarte. To OSOBNE zapytanie — nie dotyka RCP/godzin.
VPS_STOLY_URL=https://twoja-domena.pl/api/gastro/stoly
#    Zwraca rewiry sal/wynos (Numer) ORAZ kuchnię jako pseudo-rewir -1 (DANIA do wydania: niewydane pozycje
#    kierunku Kuchnia na otwartych rachunkach realnych rewirow - bez R2Piw i innych nie-stolowych kont).
STOLY_SQL=SELECT u.Numer AS rewir_nr, COUNT(r.ID) AS otwarte FROM dbo.NGastroUzytkownik u WITH (NOLOCK) LEFT JOIN dbo.NGastroDTRachunek r WITH (NOLOCK) ON r.UzytkownikOtwierajacyID = u.ID AND r.DataZamkniecia < '1900-01-02' AND r.DataOtwarcia >= DATEADD(HOUR, -18, GETDATE()) WHERE u.Numer IN (42,52,53,54,55,56,57,108,46) GROUP BY u.Numer UNION ALL SELECT -1 AS rewir_nr, COUNT(DISTINCT kds.DTRachunekPozycjaID) AS otwarte FROM dbo.NGastroKDSRachunekPozycja kds WITH (NOLOCK) JOIN dbo.NGastroDTRachunekPozycja poz WITH (NOLOCK) ON poz.ID = kds.DTRachunekPozycjaID JOIN dbo.NGastroDTRachunek r WITH (NOLOCK) ON r.ID = poz.DTRachunekID JOIN dbo.NGastroUzytkownik u WITH (NOLOCK) ON u.ID = r.UzytkownikOtwierajacyID JOIN dbo.NGastroTowar t WITH (NOLOCK) ON t.ID = poz.TowarID JOIN dbo.NGastroLokalGrupaTowarowaKierunekRozchodu gk WITH (NOLOCK) ON gk.GrupaTowarowaID = t.GrupaTowarowaID WHERE kds.DataWydania < '1900-01-02' AND r.DataZamkniecia < '1900-01-02' AND u.Numer IN (42,52,56,57,53,54,55,108,46) AND gk.KierunekRozchoduID = 'B258F91C-7F4D-4F0F-A0C7-7770E661EB63'

# 6) STOŁY — HISTORIA (liczba stolików/dzień, ostatnie 30 dni) — OPCJONALNE. Osobne zapytanie, nie dotyka RCP.
#    Zwraca: data (DATE), liczba (INT) = liczba WSZYSTKICH ZAMKNIETYCH rachunkow danego dnia (po dacie otwarcia).
VPS_STOLY_HISTORIA_URL=https://twoja-domena.pl/api/gastro/stoly-historia
STOLY_HISTORIA_SQL=SELECT CONVERT(date, r.DataOtwarcia) AS data, COUNT(*) AS liczba FROM dbo.NGastroDTRachunek r WITH (NOLOCK) WHERE r.DataZamkniecia >= '1900-01-02' AND r.DataOtwarcia >= DATEADD(day, -30, CAST(GETDATE() AS date)) GROUP BY CONVERT(date, r.DataOtwarcia)

# 7) ROZLICZENIA KELNERÓW (kwoty deklarowane z POS) — OPCJONALNE. Osobne zapytanie, nie dotyka RCP.
#    Zwraca: poz_id, rozliczenie_id, imie_nazwisko, data, zamknieto, zamkniete, forma, sprzedaz, deklarowane.
#    Źródło: NGastroZmianaRozliczeniePracownika + Totalizer per forma płatności (SaldoKoncoweDeklarowane
#    = kwota deklarowana przez kelnera; FlgZamkniete 0->1 = kelner własnie sie rozliczyl). Parametry @start/@end.
VPS_ROZLICZENIA_URL=https://twoja-domena.pl/api/gastro/rozliczenia
ROZLICZENIA_SQL=SELECT CONVERT(NVARCHAR(36), t.ID) AS poz_id, CONVERT(NVARCHAR(36), z.ID) AS rozliczenie_id, LTRIM(RTRIM(o.Imie + ' ' + o.Nazwisko)) AS imie_nazwisko, CAST(z.DataOtwarcia AS DATE) AS data, CASE WHEN z.DataZamkniecia < '1900-01-02' THEN NULL ELSE z.DataZamkniecia END AS zamknieto, z.FlgZamkniete AS zamkniete, fp.Nazwa AS forma, t.Sprzedaz AS sprzedaz, t.SaldoKoncoweDeklarowane AS deklarowane FROM dbo.NGastroZmianaRozliczeniePracownika z WITH (NOLOCK) JOIN dbo.NGastroZmianaRozliczeniePracownikaTotalizerRodzajPlatnosci t WITH (NOLOCK) ON t.ZmianaRozliczeniePracownikaID = z.ID JOIN dbo.NGastroUzytkownik u WITH (NOLOCK) ON u.ID = z.UzytkownikID JOIN dbo.NSysOperator o WITH (NOLOCK) ON o.ID = u.OperatorID JOIN dbo.NGastroFormaPlatnosci fp WITH (NOLOCK) ON fp.ID = t.FormaPlatnosciID WHERE CAST(z.DataOtwarcia AS DATE) BETWEEN @start AND @end

# 8) ZADATKI (KP "Kasa przyjela") — OPCJONALNE. Dokumenty kasowe NGastroKasaDokument TypOperacji=0.
#    Zwraca: id (GUID dokumentu), numer, kwota, opis, data (wystawienia). Parametry @start/@end
#    (agent daje szerokie okno ~120 dni, bo zadatki przyjmuje sie z duzym wyprzedzeniem). Tylko odczyt.
VPS_ZADATKI_URL=https://twoja-domena.pl/api/gastro/zadatki
ZADATKI_SQL=SELECT CONVERT(NVARCHAR(36), kd.ID) AS id, kd._c_NumerCaly AS numer, kd.Kwota AS kwota, kd.Opis AS opis, CAST(kd._c_DataWystawienia AS DATE) AS data FROM dbo.NGastroKasaDokument kd WITH (NOLOCK) WHERE kd.TypOperacji = 0 AND CAST(kd._c_DataWystawienia AS DATE) BETWEEN @start AND @end

# 9) STORNA/RABATY/ANULACJE (antyfraud) — OPCJONALNE. Zdarzenia per kelner do porownania
#    z reszta zespolu (zakladka "Antyfraud POS"). UWAGA: schemat storn ROZNI SIE miedzy
#    wersjami Gastro — PRZED wlaczeniem zweryfikuj tabele/kolumny narzedziem odkryj_schemat.ps1
#    i dostosuj zapytanie. Wymagane kolumny: id (GUID), data, imie_nazwisko, typ
#    ('storno'|'rabat'|'anulacja'), kwota; opcjonalne: opis, godzina. Parametry @start/@end.
#VPS_STORNA_URL=https://twoja-domena.pl/api/gastro/storna
#STORNA_SQL=SELECT CONVERT(NVARCHAR(36), sp.ID) AS id, CAST(sp.Data AS DATE) AS data, LTRIM(RTRIM(o.Imie + ' ' + o.Nazwisko)) AS imie_nazwisko, 'storno' AS typ, ABS(sp.Kwota) AS kwota, sp.Opis AS opis, CONVERT(TIME, sp.Data) AS godzina FROM dbo.NGastroDTRachunekPozycjaStorno sp WITH (NOLOCK) JOIN dbo.NGastroUzytkownik u WITH (NOLOCK) ON u.ID = sp.UzytkownikID JOIN dbo.NSysOperator o WITH (NOLOCK) ON o.ID = u.OperatorID WHERE CAST(sp.Data AS DATE) BETWEEN @start AND @end
