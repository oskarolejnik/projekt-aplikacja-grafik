# ── Konfiguracja agenta RCP (skopiuj do `.env` i uzupełnij) ──────────────────
# UWAGA: .env trzymaj TYLKO na serwerze lokalnym. Nigdy w repo, nigdy na VPS.

# 1) Połączenie do bazy RCP — KONTO TYLKO DO ODCZYTU (poproś IT Admina).
#    Hasło ze znakami specjalnymi zakoduj URL-em (np. @ -> %40).
RCP_DATABASE_URL=mssql+pymssql://czytelnik_rcp:HASLO@127.0.0.1:1433/NazwaBazyRCP

# 2) Zapytanie odczytujące odbicia. MUSI zwrócić aliasy:
#    rcp_id, imie_nazwisko, data, wejscie, wyjscie  (parametry :start, :end)
#    To jest SZABLON — podmień nazwy tabel/kolumn na swoje (użyj odkryj_schemat.py).
#    Dobrze dodać też WITH (NOLOCK) przy tabelach, oprócz globalnego READ UNCOMMITTED.
RCP_SQL=SELECT CAST(z.Id AS NVARCHAR(50)) AS rcp_id, (p.Imie + ' ' + p.Nazwisko) AS imie_nazwisko, CAST(z.Wejscie AS DATE) AS data, z.Wejscie AS wejscie, z.Wyjscie AS wyjscie FROM Zmiany z WITH (NOLOCK) JOIN Pracownicy p WITH (NOLOCK) ON p.Id = z.PracownikId WHERE CAST(z.Wejscie AS DATE) BETWEEN :start AND :end

# 3) Adres endpointu na VPS (HTTPS!) i wspólny token (taki sam jak RCP_INGEST_TOKEN na VPS).
VPS_INGEST_URL=https://twoja-domena.pl/api/rcp/ingest
RCP_INGEST_TOKEN=wygeneruj-dlugi-losowy-sekret

# 4) Parametry pętli (opcjonalne).
POLL_SECONDS=30      # co ile sekund odpytywać RCP (30-60 = praktycznie na żywo)
OKNO_DNI=2           # ile dni wstecz skanować w każdym cyklu (lekkie zapytanie)
QUERY_TIMEOUT=15
