# Skopiuj do backend/.env i dostosuj wartości.

# --- Tryb aplikacji ---
# production (domyślnie) → "secure by default": aplikacja ODMÓWI STARTU, gdy SECRET_KEY
#   lub RCP_INGEST_TOKEN mają wartości domyślne/przykładowe (fail-fast).
# development → te same problemy są tylko ostrzeżeniami (wygodna praca lokalna).
APP_ENV=development

# --- Baza danych ---
# PostgreSQL (cel produkcyjny). Dla szybkiego dev można użyć SQLite:
#   DATABASE_URL=sqlite:///./scheduler.db
DATABASE_URL=postgresql+psycopg2://grafik:grafik@localhost:5432/grafik

# --- Bezpieczeństwo ---
# Sekret do podpisywania tokenów JWT. USTAW własny, długi, losowy ciąg!
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=zmien-mnie-na-dlugi-losowy-sekret
# Czas życia tokenu dostępu (w minutach)
TOKEN_TTL_MINUTES=720

# --- Konto administratora ---
# Tworzenie admina z .env jest WYŁĄCZONE. Admina zakłada się skryptem:
#   python create_admin.py
# (Poniższe zmienne są ignorowane — możesz je pominąć.)

# --- CORS ---
# Lista dozwolonych originów oddzielona przecinkami.
# PUSTE (zalecane w produkcji) → tylko same-origin: backend serwuje frontend z tego
#   samego adresu, więc cross-origin nie jest potrzebny.
# W dev (APP_ENV=development) puste = automatycznie dozwolone localhost:5173/8000 (proxy Vite).
# Jeśli frontend stoi pod inną domeną, podaj ją wprost, np. https://grafik.twojadomena.pl
CORS_ORIGINS=

# --- Powiadomienia Web Push (PWA) ---
# Wygeneruj klucze raz:  python generate_vapid.py  (i wklej wynik tutaj)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=vapid_private.pem
VAPID_SUBJECT=mailto:admin@twojadomena.pl

# --- Agent RCP / stoły (Gastro) ---
# Ten sam token co w agent_rcp.env na serwerze lokalnym (nagłówek X-RCP-Token).
RCP_INGEST_TOKEN=ten-sam-dlugi-sekret-co-w-agencie
# Okno (minuty) wysyłania pushy o wejściu/wyjściu — tylko świeże zdarzenia.
RCP_POWIADOM_OKNO_MIN=60

# --- Rezerwacje (Google Calendar, konto serwisowe) ---
# Ścieżka do pliku JSON konta serwisowego (trzymaj poza repo, chmod 600).
GOOGLE_SA_JSON=/sciezka/do/google_sa.json
# ID kalendarza z rezerwacjami (udostępniony e-mailowi konta serwisowego).
GOOGLE_CALENDAR_ID=twoje_id@group.calendar.google.com

# --- E-mail (SMTP) — potwierdzenia rezerwacji (opcjonalne) ---
# Brak kompletu = integracja e-mail wyłączona (potwierdzenia nie są wysyłane, bez błędu).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                          # adres nadawcy (domyślnie SMTP_USER)
